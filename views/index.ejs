<%- include('partials/header') %>

<div class="app-layout">
  <!-- 顶部工具栏 -->
  <div class="toolbar">
    <div class="toolbar-left">
      <button class="toolbar-btn" id="btnAdd" onclick="toggleAddMode()">📍 <%= t('cache.create') %></button>
    </div>
    <div class="toolbar-right">
      <div class="search-bar">
        <input type="text" id="searchInput" placeholder="<%= t('map.search') %>"
               value="<%= search %>" onkeydown="if(event.key==='Enter') searchCaches()">
        <button class="btn-icon" onclick="searchCaches()">🔍</button>
      </div>
    </div>
  </div>

  <!-- 主内容区：地图 + 侧栏列表 -->
  <div class="main-content">
    <div id="map" class="map-panel"></div>

    <div class="sidebar">
      <div class="sidebar-header">
        <span>📋 <%= t('cache.listView') %></span>
        <span class="sidebar-count" id="sidebarCount">0</span>
      </div>
      <div class="sidebar-list" id="sidebarList">
        <div class="sidebar-empty">移动地图查看范围内的藏宝点</div>
      </div>
    </div>
  </div>
</div>

<!-- 地图点击添加藏宝点弹窗 -->
<div class="modal-overlay" id="addModal" style="display:none" onclick="closeAddModal(event)">
  <div class="modal" onclick="event.stopPropagation()">
    <h2><%= t('cache.create') %></h2>
    <p class="hint"><%= t('map.placeMode') %></p>
    <form id="addForm" onsubmit="submitCache(event)">
      <label><%= t('form.name') %> <span class="req">*</span></label>
      <input type="text" name="name" placeholder="<%= t('form.namePlaceholder') %>" required>

      <div class="form-row">
        <div class="form-col">
          <label><%= t('form.lat') %> <span class="req">*</span></label>
          <input type="number" id="cacheLat" name="lat" step="0.000001" placeholder="例如 39.9042" required>
        </div>
        <div class="form-col">
          <label><%= t('form.lng') %> <span class="req">*</span></label>
          <input type="number" id="cacheLng" name="lng" step="0.000001" placeholder="例如 116.4074" required>
        </div>
      </div>

      <label><%= t('form.description') %></label>
      <textarea name="description" rows="3" placeholder="<%= t('form.descriptionPlaceholder') %>"></textarea>

      <p class="hint" style="margin-top:8px">点击地图自动填入坐标，或直接输入</p>

      <div class="form-actions">
        <button type="button" class="btn-cancel" onclick="closeAddModal()"><%= t('form.cancel') %></button>
        <button type="submit" class="btn-primary"><%= t('form.submit') %></button>
      </div>
    </form>
    <div class="error-msg" id="addError"></div>
  </div>
</div>



<!-- 藏宝点详情弹窗 -->
<div class="modal-overlay" id="detailModal" style="display:none" onclick="closeDetail(event)">
  <div class="modal modal-wide" onclick="event.stopPropagation()" id="detailContent">
    <!-- filled by JS -->
  </div>
</div>

<script>
const LANG = '<%= lang %>';
const T = {
  detailLink: '<%= lang === "zh" ? "查看详情 →" : "View details →" %>',
};
</script>
<%- include('partials/footer') %>
<script src="/js/map.js"></script>
</body>
</html>
