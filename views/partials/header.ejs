<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title><%= t('site.title') %></title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.css" />
<link rel="stylesheet" href="/css/style.css" />
</head>
<body>

<nav class="nav">
  <a href="/" class="nav-brand"><%= t('site.title') %></a>
  <div class="nav-links">
    <% if (currentUser) { %>
      <span class="nav-user"><%= currentUser.nickname %></span>
      <a href="/" class="nav-btn"><%= t('nav.home') %></a>
      <button class="nav-btn" onclick="logout()"><%= t('nav.logout') %></button>
    <% } else { %>
      <a href="/login?lang=<%= lang %>" class="nav-btn"><%= t('nav.login') %></a>
    <% } %>
    <select class="lang-switch" onchange="switchLang(this.value)">
      <option value="zh" <%= lang === 'zh' ? 'selected' : '' %>>中文</option>
      <option value="en" <%= lang === 'en' ? 'selected' : '' %>>EN</option>
    </select>
  </div>
</nav>
